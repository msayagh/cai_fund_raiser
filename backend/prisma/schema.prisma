
generator client {
  provider = "prisma-client-js"
}

datasource db {
  // `npm run prisma:run` rewrites this provider from DB_PROVIDER (mysql/sqlite).
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Donor {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  accountCreated Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  engagement         Engagement?
  payments           Payment[]
  requests           Request[]
  logs               ActivityLog[]
  refreshTokens      RefreshToken[]
  volunteerSignups   ActivitySignup[] @relation("DonorVolunteerSignups")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  addedById    String?
  addedBy      Admin?   @relation("AdminHierarchy", fields: [addedById], references: [id])
  addedAdmins  Admin[]  @relation("AdminHierarchy")

  paymentsRecorded    Payment[]
  logs                ActivityLog[]
  refreshTokens       RefreshToken[]
  createdApiKeys      ApiKey[]
  volunteerActivities VolunteerActivity[] @relation("AdminVolunteerActivities")
}

model Engagement {
  id          String    @id @default(cuid())
  donorId     String    @unique
  donor       Donor     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  totalPledge Float
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Payment {
  id                String   @id @default(cuid())
  externalEntryId   String?
  donorId           String
  donor             Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  amount            Float
  quantity          Int      @default(1)
  date              DateTime
  method            String
  note              String?
  displayName       String?
  engagement        Float
  tier              String
  recordedByAdminId String?
  recordedByAdmin   Admin?   @relation(fields: [recordedByAdminId], references: [id])
  createdAt         DateTime @default(now())

  @@index([externalEntryId])
}

model Request {
  id        String   @id @default(cuid())
  type      String
  donorId   String?
  donor     Donor?   @relation(fields: [donorId], references: [id])
  name      String
  email     String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments RequestAttachment[]
}

model RequestAttachment {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  filePath  String
  fileSize  Int
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actor     String
  actorType String
  actorId   String?
  action    String
  details   String
  donorId   String?
  donorRef  Donor?   @relation(fields: [donorId], references: [id])
  adminId   String?
  adminRef  Admin?   @relation(fields: [adminId], references: [id])
  timestamp DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userType  String
  donorId   String?
  donor     Donor?   @relation(fields: [donorId], references: [id], onDelete: Cascade)
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApiKey {
  id               String   @id @default(cuid())
  title            String
  keyPrefix        String
  keyHash          String   @unique
  isActive         Boolean  @default(true)
  createdByAdminId String?
  createdByAdmin   Admin?   @relation(fields: [createdByAdminId], references: [id])
  lastUsedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Volunteering Feature ─────────────────────────────────────────────────────

model VolunteerActivity {
  id               String   @id @default(cuid())
  title            String
  description      String   
  skills           String?
  recurrenceType   String   @default("none")
  recurrenceNote   String?
  maxVolunteers    Int      @default(0)
  estimatedMinutes Int?
  isActive         Boolean  @default(true)
  createdByAdminId String
  createdByAdmin   Admin    @relation("AdminVolunteerActivities", fields: [createdByAdminId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  schedules      ActivitySchedule[]
  signups        ActivitySignup[]
  discussions    ActivityDiscussion[]
  checklistItems ActivityChecklistItem[]
}

model ActivitySchedule {
  id            String            @id @default(cuid())
  activityId    String
  activity      VolunteerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  location      String?
  notes         String?
  maxVolunteers Int?
  status        String            @default("upcoming")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  signups ActivitySignup[]
}

model ActivitySignup {
  id         String            @id @default(cuid())
  activityId String
  activity   VolunteerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  scheduleId String
  schedule   ActivitySchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  donorId    String
  donor      Donor             @relation("DonorVolunteerSignups", fields: [donorId], references: [id], onDelete: Cascade)
  note       String?
  status     String            @default("signed_up")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  checklistProgress SignupChecklist[]

  @@unique([scheduleId, donorId])
}

model ActivityDiscussion {
  id         String            @id @default(cuid())
  activityId String
  activity   VolunteerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  authorId   String
  authorType String
  authorName String
  message    String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

// Generic key-value store for application settings
model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── Volunteering Checklist ───────────────────────────────────────────────────

model ActivityChecklistItem {
  id         String            @id @default(cuid())
  activityId String
  activity   VolunteerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  title      String
  order      Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  checkProgress SignupChecklist[]
}

model SignupChecklist {
  id              String                @id @default(cuid())
  signupId        String
  signup          ActivitySignup        @relation(fields: [signupId], references: [id], onDelete: Cascade)
  checklistItemId String
  checklistItem   ActivityChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  checkedAt       DateTime              @default(now())

  @@unique([signupId, checklistItemId])
}
