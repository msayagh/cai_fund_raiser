generator client {
  provider = "prisma-client-js"
}

datasource db {
  // `npm run prisma:run` rewrites this provider from DB_PROVIDER (mysql/sqlite).
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Donor {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  isActive      Boolean  @default(true)
  
  // New profile fields
  phoneNumber   String?
  address       String?
  city          String?
  country       String?
  postalCode    String?
  dateOfBirth   DateTime?
  taxNumber     String?
  companyName   String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  engagement    Engagement?
  payments      Payment[]
  requests      Request[]
  logs          ActivityLog[]
  refreshTokens RefreshToken[]
  donorRoles    DonorRole[]
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  addedById    String?
  addedBy      Admin?   @relation("AdminHierarchy", fields: [addedById], references: [id])
  addedAdmins  Admin[]  @relation("AdminHierarchy")

  paymentsRecorded Payment[]
  logs             ActivityLog[]
  refreshTokens    RefreshToken[]
  adminRoles       AdminRole[]
}

model Engagement {
  id          String    @id @default(cuid())
  donorId     String    @unique
  donor       Donor     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  totalPledge Float
  startDate   DateTime
  endDate     DateTime?
  // Pillar breakdown: JSON object with foundation, walls, arches, dome amounts
  pillars     Json?     @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Payment {
  id                String   @id @default(cuid())
  donorId           String
  donor             Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  amount            Float
  date              DateTime
  method            String
  note              String?
  receiptPath       String?
  recordedByAdminId String?
  recordedByAdmin   Admin?   @relation(fields: [recordedByAdminId], references: [id])
  createdAt         DateTime @default(now())
}

model Request {
  id        String   @id @default(cuid())
  type      String
  donorId   String?
  donor     Donor?   @relation(fields: [donorId], references: [id])
  name      String
  email     String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments RequestAttachment[]
}

model RequestAttachment {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  filePath  String
  fileSize  Int
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actor     String
  actorType String
  actorId   String?
  action    String
  details   String
  donorId   String?
  donorRef  Donor?   @relation(fields: [donorId], references: [id])
  adminId   String?
  adminRef  Admin?   @relation(fields: [adminId], references: [id])
  timestamp DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleCapabilities RoleCapability[]
  adminRoles       AdminRole[]
  donorRoles       DonorRole[]

  @@index([name])
}

model Capability {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String   // e.g., "admin.donors", "admin.requests", "donor.profile"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roleCapabilities RoleCapability[]

  @@index([module])
}

model RoleCapability {
  id            String      @id @default(cuid())
  roleId        String
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  capabilityId  String
  capability    Capability  @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([roleId, capabilityId])
  @@index([roleId])
  @@index([capabilityId])
}

model AdminRole {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@unique([adminId, roleId])
  @@index([adminId])
  @@index([roleId])
}

model DonorRole {
  id        String   @id @default(cuid())
  donorId   String
  donor     Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@unique([donorId, roleId])
  @@index([donorId])
  @@index([roleId])
}


model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userType  String
  donorId   String?
  donor     Donor?   @relation(fields: [donorId], references: [id], onDelete: Cascade)
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model GlobalGoal {
  id        String   @id @default(cuid())
  amount    Float    @default(0)
  raised    Float    @default(0)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model Campaign {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  goal        Float    @default(0)
  raised      Float    @default(0)
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("active") // active, completed, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([status])
}

model Pillar {
  id           String   @id @default(cuid())
  name         String   @unique // foundation, walls, arches, dome
  amount       Float    @default(0)
  arabicName   String?
  icon         String?
  color        String?
  lightColor   String?
  updatedAt    DateTime @updatedAt
  updatedBy    String?

  @@index([name])
}
