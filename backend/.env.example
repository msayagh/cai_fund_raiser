# Server
PORT=3001
NODE_ENV=development

# Database
# Switch between providers here: mysql | sqlite
DB_PROVIDER=mysql

# Optional manual override. Leave empty to auto-build from values below.
DATABASE_URL=

# SQLite config (used when DB_PROVIDER=sqlite)
SQLITE_DATABASE_URL="file:./dev.db"

# MySQL config (used when DB_PROVIDER=mysql)
DB_HOST=
DB_PORT=
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# JWT (use strong random secrets in production!)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# SMTP (leave empty to log OTPs to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Centre Zad Al-Imane <noreply@ccai.com>"

# Dev-only OTP bypass (disable in production)
OTP_BYPASS_ENABLED=true
OTP_BYPASS_CODE=111111

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=
