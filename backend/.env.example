# Server
PORT=3001
NODE_ENV=development

# Database (SQLite for dev, change to postgresql:// for prod)
DATABASE_URL="file:./dev.db"

# JWT (use strong random secrets in production!)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# SMTP (leave empty to log OTPs to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Masjid Al-Noor <noreply@masjid.com>"

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
