{
  "name": "mosque-app-backend",
  "version": "1.0.0",
  "description": "Mosque donation tracker backend API",
  "main": "server.js",
  "scripts": {
    "prisma:run": "node scripts/run-prisma.js",
    "predev": "npm run db:generate",
    "dev": "node --watch server.js",
    "prestart": "npm run db:generate",
    "start": "node server.js",
    "db:migrate": "npm run prisma:run -- db push",
    "db:migrate:dev": "npm run prisma:run -- migrate dev",
    "db:generate": "npm run prisma:run -- generate",
    "db:seed": "npm run db:generate && node prisma/seed.js",
    "db:studio": "npm run prisma:run -- studio",
    "db:reset": "npm run prisma:run -- db push --force-reset && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
